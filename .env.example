# Copy this file to .env and fill in the values

# Neon Postgres connection string
# Paste the connection string directly from Neon - the app handles conversion automatically
# (supports sslmode, channel_binding, and other Neon-specific params)
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# Anthropic API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# MLB Stats API base URLs (no key required, these are public)
MLB_STATS_API_BASE_URL=https://statsapi.mlb.com/api/v1
MLB_STATS_API_LIVE_URL=https://ws.statsapi.mlb.com/api/v1.1

# Debug mode (set to true for development)
DEBUG=true

# Cache TTL in seconds (default 5 minutes)
CACHE_TTL_SECONDS=300
